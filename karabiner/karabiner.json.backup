{
  "profiles": [
    {
      "name": "Default profile",
      "selected": true,
      "virtual_hid_keyboard": { "keyboard_type_v2": "ansi" },
      "complex_modifications": {
        "rules": [
          {
            "description": "Caps Lock → Esc (tap) / Hyper (hold)",
            "manipulators": [
              {
                "type": "basic",
                "from": {
                  "key_code": "caps_lock",
                  "modifiers": {
                    "optional": ["any"]
                  }
                },
                "to": [
                  {
                    "key_code": "left_shift",
                    "modifiers": ["left_command", "left_control", "left_option"]
                  }
                ],
                "to_if_alone": [
                  {
                    "key_code": "escape"
                  }
                ]
              }
            ]
          },
          {
            "description": "Hyper+V → Voice Input",
            "manipulators": [
              {
                "type": "basic",
                "from": {
                  "key_code": "v",
                  "modifiers": {
                    "mandatory": ["left_shift", "left_command", "left_control", "left_option"]
                  }
                },
                "to": [
                  {
                    "shell_command": "/Users/aryk/workspace/pai/.opencode/bin/voice-input-wrapper.sh"
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  ]
}
